require("bufferline").setup{
  options = {
    offsets = {
      {
        filetype = "NvimTree",
        text = "File Explorer",
        highlight = "Directory",
        text_align = "left"
      }
    },
    show_buffer_close_icons = false,
    show_close_icon = false,
    separator_style = "slant",

    custom_filter = function(buf)
      local bt = vim.bo[buf].buftype
      return bt == "" or bt == "help"
    end,
  }
}

